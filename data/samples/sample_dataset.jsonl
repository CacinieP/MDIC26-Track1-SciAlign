ction": null, "mineru_parsed": false}, "language": "en"}, {"type": "general_description", "content": "多巴胺是一种儿茶酚胺类神经递质和激素，在奖赏、动机、记忆和运动控制中发挥关键作用。多巴胺信号异常与帕金森病、精神分裂症和成瘾有关。", "source": {"type": "manual_curation", "reference": "CID 681", "section": null, "mineru_parsed": false}, "language": "zh"}, {"type": "general_description", "content": "published: 22 December 2017 doi: 10.3389/fnins.2017.00724 Frontiers in Neuroscience | www.frontiersin.org 1 December 2017 | Volume 11 | Article 724", "source": {"type": "paper", "reference": "doi:10.3389/fnins.2017.00724", "section": "REVIEW", "mineru_parsed": true}, "language": "en"}], "entity_relations": [{"subject": "Dopamine", "relation": "binds_to", "object": "D1 receptor", "confidence": 0.99}, {"subject": "Dopamine", "relation": "binds_to", "object": "D2 receptor", "confidence": 0.99}, {"subject": "Dopamine", "relation": "synthesized_from", "object": "L-DOPA", "confidence": 0.99}, {"subject": "Dopamine", "relation": "metabolized_to", "object": "norepinephrine", "confidence": 0.98}], "alignment_metadata": {"alignment_confidence": 0.9, "validation_status": "automated_pass", "mineru_usage": [{"tool": "MinerU Open Source", "task": "Parsed Dopamine pharmacology paper (12 pages) via MinerU Open Source (PyMuPDF engine), extracted 1 figures and structured text", "input": "data/raw/papers/dopamine_neuroscience.pdf", "output": "data/raw/parsed/dopamine_neuroscience/mineru_parsed.json", "parse_time": "2026-05-31T01:55:24Z", "pages_processed": 12, "figures_extracted": 1}, {"tool": "MinerU Skills", "task": "Used MinerU document structure analysis skill to identify sections and extract molecular structure figures from Dopamine review paper", "input": "data/raw/papers/dopamine_neuroscience.pdf", "output": "data/raw/parsed/dopamine_neuroscience/images/", "figures_identified": 1}], "created_at": "2026-05-30T20:16:18Z", "version": "2.0.0", "updated_at": "2026-05-30T20:35:13Z"}, "category": "Neurotransmitter"}
