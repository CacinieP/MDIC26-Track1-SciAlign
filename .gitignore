data/raw/**/*.zip

# Parsed MinerU markdown outputs are part of the auditable dataset evidence.

# Parsed paper outputs (images + intermediate JSON, 24MB)
# Note: actual directory is data/raw/parsed_mineru_api/
data/raw/parsed_mineru_api/images/
data/raw/parsed_mineru_api/*.json
!data/raw/parsed_mineru_api/parsing_log.json

